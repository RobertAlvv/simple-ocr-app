# OCR Processing environment variables
# Copy this file to .env and fill in the values

FIREBASE_API_KEY=your_firebase_api_key_here
APP_NAME=OCR Processing

# Android emulator apunta al host mediante 10.0.2.2
OCR_API_BASE_URL=http://10.0.0.6:8000

# Descomentar para iOS simulator:
# OCR_API_BASE_URL=http://localhost:8000
